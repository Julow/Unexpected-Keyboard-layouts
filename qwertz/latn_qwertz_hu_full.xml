<?xml version="1.0" encoding="utf-8"?>
<keyboard name="QWERTZ (Magyar általános nagy)" script="latin" bottom_row="false" locale_extra_keys="false">
  <!-- Keyboard rows are 12 units wide -->
  <row>
    <key c="q" nw="loc esc" ne="0" sw="loc §" se="\\"/>
    <key c="w" nw="'" ne="1" sw="~" se="|"/>
    <key c="e" nw="&quot;" ne="2" sw="loc accent_caron" se="¦"/>
    <key c="r" nw="+" ne="3" se="^"/>
    <key c="t" nw="!" ne="4" sw="loc accent_breve"/>
    <key c="z" nw="%" ne="5" sw="undo" se="°"/>
    <key c="u" nw="/" ne="6" sw="loc accent_ogonek" se="€"/>
    <key c="i" nw="=" ne="7" sw="loc accent_grave" se="`"/>
    <key c="o" nw="(" ne="8" sw="loc accent_dot_above"/>
    <key c="p" nw=")" ne="9" sw="loc accent_aigu"/>
    <key c="ó" nw="loc accent_circonflexe" ne="f11_placeholder" sw="loc accent_double_aigu" se="÷"/>
    <key c="ú" ne="f12_placeholder" sw="loc accent_trema" se="×"/>
  </row>
  <row>
    <key c="a" nw="loc tab" ne="loc selectAll" se="ä"/>
    <key c="s" nw="„" ne="¹" se="đ"/>
    <key c="d" nw="”" ne="²"/>
    <key c="f" nw="’" ne="³" se="["/>
    <key c="g" ne="loc superscript" sw="©" se="]"/>
    <key c="h" ne="loc subscript" sw="®" se="("/>
    <key c="j" sw="™" se=")"/>
    <key c="k" nw="≠" se="ł"/>
    <key c="l" w="left" e="right" n="up" s="down"/>
    <key c="é" sw="loc £" se="$"/>
    <key c="á" sw="±" se="loc ß"/>
    <key c="ü" nw="ű" sw="loc accent_ring" se="¤"/>
  </row>
  <row>
    <key width="1.5" c="shift" n="loc capslock" s="loc compose"/>
    <key c="í" nw="≤" se="&lt;"/>
    <key c="y" nw="≥" sw="redo" se="&gt;"/>
    <key c="x" ne="loc cut" se="\#"/>
    <key c="c" ne="loc copy" se="&amp;"/>
    <key c="v" ne="loc paste" se="\@"/>
    <key c="b" ne="loc pasteAsPlainText" se="{"/>
    <key c="n" sw="✗" se="}"/>
    <key c="m" ne="·" sw="✓" se=".hu:.hu,action"/>
    <key c="ö" nw="ő" sw="→" se=".com:.com,action"/>
    <key width="1.5" c="backspace" w="loc delete_word" e="delete" n="loc forward_delete_word" s="insert"/>
  </row>
  <row>
    <key width="1.8" c="switch_numeric" w="loc meta" e="ctrl" n="loc switch_clipboard" s="loc switch_greekmath"/>
    <key width="1.3" c="switch_emoji" w="loc alt" e="fn" n="🙂" s="❤️"/>
    <key width="4.4" c="space" w="cursor_left" e="cursor_right" n="loc voice_typing" s="hide_self" nw="loc home" sw="loc end" ne="loc page_up" se="loc page_down"/>
    <key c="," n="?" w="!" e=";"/>
    <key c="." n=":" w="…" e="•"/>
    <key c="-" n="_" w="–" e="*"/>
    <key width="1.5" c="enter" n="action" w="config" e="switch_forward" s="switch_backward"/>
  </row>
  <modmap>
    <fn a="0" b="f1"/>
    <fn a="1" b="f2"/>
    <fn a="2" b="f3"/>
    <fn a="3" b="f4"/>
    <fn a="4" b="f5"/>
    <fn a="5" b="f6"/>
    <fn a="6" b="f7"/>
    <fn a="7" b="f8"/>
    <fn a="8" b="f9"/>
    <fn a="9" b="f10"/>
    <fn a="left" b="home"/>
    <fn a="right" b="end"/>
    <fn a="up" b="page_up"/>
    <fn a="down" b="page_down"/>
    <ctrl a="home" b=""/>
    <ctrl a="end" b=""/>
    <ctrl a="page_up" b="⤒:ctrl,home"/>
    <ctrl a="page_down" b="⤓:ctrl,end"/>
    <fn a="backspace" b="delete"/>
    <fn a="delete_word" b="forward_delete_word"/>
    <fn a="delete" b=""/>
    <fn a="enter" b="action"/>
    <fn a="action" b=""/>
    <fn a="🙂" b="🙁"/>
    <fn a="❤️" b="💔"/>
    <fn a="'" b="'"/>
    <fn a="|" b="|"/>
    <fn a="&quot;" b="&quot;"/>
    <fn a="undo" b="undo"/>
    <fn a="€" b="€"/>
    <fn a="[" b="["/>
    <fn a="]" b="]"/>
    <fn a="(" b="("/>
    <fn a=")" b=")"/>
    <fn a="£" b="£"/>
    <fn a="." b="."/>
  </modmap>
</keyboard>
